              "raw": "{{base_url}}/api/pecas",
              "host": ["{{base_url}}"],
              "path": ["api", "pecas"]
            }
          }
        },
        {
          "name": "POST Funcionários (Dados Dinâmicos)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"NumeroMecanografico\": \"PERF_{{$timestamp}}\",\n    \"Nome\": \"Operador Performance {{$randomUUID}}\",\n    \"Email\": \"perf_{{$timestamp}}@mobifix.pt\",\n    \"Contacto\": \"910000000\",\n    \"Cargo\": \"OPERADOR\",\n    \"PasswordHash\": \"hash_perf_123\",\n    \"Ativo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/funcionarios",
              "host": ["{{base_url}}"],
              "path": ["api", "funcionarios"]
            }
          }
        }
      ]
    },
    {
      "name": "Cenário 3: Carga de Pico",
      "description": "Objetivo: Identificar limites de saturação e degradação de performance.\nConfiguração no Runner: 50 VUs, Duração 2 min.",
