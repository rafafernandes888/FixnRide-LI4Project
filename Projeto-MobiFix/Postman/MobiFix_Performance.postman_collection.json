{
  "info": {
    "name": "MobiFix - Data API (Testes de Performance)",
    "description": "Coleção estruturada para os testes de stress e performance definidos no Capítulo 4 do relatório Fix'n'Ride. Contém os 3 cenários de carga descritos na Tabela 4.2.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Cenário 1: Carga Base",
      "description": "Objetivo: Estabelecer baseline de performance em carga normal de balcão.\nConfiguração no Runner: 5 VUs, Duração 1 min.",
      "item": [
        {
          "name": "GET Serviços",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/servicos",
              "host": ["{{base_url}}"],
              "path": ["api", "servicos"]
            }
          }
        },
        {
          "name": "GET Peças",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/pecas",
              "host": ["{{base_url}}"],
              "path": ["api", "pecas"]
            }
          }
        },
        {
          "name": "GET Funcionários",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/funcionarios",
              "host": ["{{base_url}}"],
              "path": ["api", "funcionarios"]
            }
          }
        }
      ]
    },
    {
      "name": "Cenário 2: Carga Moderada",
      "description": "Objetivo: Simular pico de utilização com múltiplos operadores simultâneos.\nConfiguração no Runner: 20 VUs, Duração 2 min.",
      "item": [
        {
          "name": "GET Serviços",
          "request": {
            "method": "GET",
            "header": [],
